<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ASF Manager PRO" Height="650" Width="1100"
        Background="#1e1e1e">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель -->
        <StackPanel Grid.Column="0" Margin="10">

            <TextBlock Text="Добавить аккаунт"
                       Foreground="White"
                       FontSize="18"
                       Margin="0,0,0,10"/>

            <TextBox x:Name="NameBox" Margin="0,5" Height="30"/>
            <TextBox x:Name="LoginBox" Margin="0,5" Height="30"/>
            <TextBox x:Name="PasswordBox" Margin="0,5" Height="30"/>
            <TextBox x:Name="EmailBox" Margin="0,5" Height="30"/>
            <TextBox x:Name="EmailPassBox" Margin="0,5" Height="30"/>
            <TextBox x:Name="ProxyBox" Margin="0,5" Height="30"/>

            <Button Content="➕ Добавить"
                    Click="Add_Click"
                    Margin="0,10"
                    Height="35"/>

            <Button Content="❌ Удалить"
                    Click="Delete_Click"
                    Height="35"/>

        </StackPanel>

        <!-- Правая панель -->
        <Grid Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Верх -->
            <StackPanel Orientation="Horizontal">
                <Button Content="🚀 Запустить"
                        Click="Run_Click"
                        Width="120"
                        Margin="5"/>

                <Button Content="🌐 Открыть профиль"
                        Click="Open_Click"
                        Width="160"
                        Margin="5"/>
            </StackPanel>

            <!-- Таблица -->
            <DataGrid x:Name="AccountsGrid"
                      Grid.Row="1"
                      AutoGenerateColumns="False"
                      Background="#2d2d2d"
                      Foreground="White"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="120"/>
                    <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="150"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                    <DataGridTextColumn Header="Прокси" Binding="{Binding Proxy}" Width="200"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                </DataGrid.Columns>

            </DataGrid>
        </Grid>

    </Grid>
</Window>
