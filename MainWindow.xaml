<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="ASF Manager PRO"
        Height="700"
        Width="1200">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ЛЕВАЯ ПАНЕЛЬ -->
        <StackPanel Grid.Column="0" Margin="20">

            <TextBlock Text="Новый аккаунт"
                       FontSize="22"
                       Margin="0,0,0,15"/>

            <TextBox x:Name="NameBox"
                     materialDesign:HintAssist.Hint="Имя"/>

            <TextBox x:Name="LoginBox"
                     materialDesign:HintAssist.Hint="Логин"
                     Margin="0,10,0,0"/>

            <TextBox x:Name="PasswordBox"
                     materialDesign:HintAssist.Hint="Пароль"
                     Margin="0,10,0,0"/>

            <TextBox x:Name="EmailBox"
                     materialDesign:HintAssist.Hint="Почта"
                     Margin="0,10,0,0"/>

            <TextBox x:Name="EmailPassBox"
                     materialDesign:HintAssist.Hint="Пароль почты"
                     Margin="0,10,0,0"/>

            <TextBox x:Name="ProxyBox"
                     materialDesign:HintAssist.Hint="Прокси"
                     Margin="0,10,0,0"/>

            <Button Content="➕ Добавить"
                    Click="Add_Click"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Margin="0,20,0,0"
                    Height="40"/>

            <Button Content="❌ Удалить"
                    Click="Delete_Click"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Margin="0,10,0,0"
                    Height="40"/>

        </StackPanel>

        <!-- ПРАВАЯ ЧАСТЬ -->
        <Grid Grid.Column="1" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- КНОПКИ -->
            <StackPanel Orientation="Horizontal">

                <Button Content="🚀 Запустить"
                        Click="Run_Click"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Margin="5"
                        Height="40"/>

                <Button Content="🌐 Открыть профиль"
                        Click="Open_Click"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Margin="5"
                        Height="40"/>

            </StackPanel>

            <!-- ТАБЛИЦА -->
            <DataGrid x:Name="AccountsGrid"
                      Grid.Row="1"
                      AutoGenerateColumns="False"
                      Style="{StaticResource MaterialDesignDataGrid}">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="150"/>
                    <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="150"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                    <DataGridTextColumn Header="Прокси" Binding="{Binding Proxy}" Width="200"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120"/>
                </DataGrid.Columns>

            </DataGrid>

        </Grid>
    </Grid>
</Window>
